{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@core-elite/native-ble/src/stub": ["../native-ble/src/stub.ts"],
      "@core-elite/native-ble": ["../native-ble/src/stub.ts"],
      "@core-elite/powersync": ["../powersync/src/index.ts"]
    }
  },
  "include": ["src/mobile/**/*"]
}
