{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src/index.ts", "src/hlc.ts", "src/native-init.ts"],
  "exclude": ["node_modules", "src/connector.ts", "src/useSync.ts", "src/useSyncState.ts", "src/schema.ts"]
}
