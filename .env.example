# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API

# Your project's REST / Auth / Storage / Realtime base URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Public anon key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── Verified Export (admin-only) ──────────────────────────────────────────────
# Used by VerifiedExportButton to authenticate calls to the
# generate-verified-export Edge Function via X-Verification-Secret header.
#
# This MUST match the VERIFICATION_SECRET stored in Supabase Edge Function
# secrets for your project:
#   npx supabase secrets set VERIFICATION_SECRET=<your-secret>
#
# Generate a fresh secret with:
#   openssl rand -hex 32
#
# SECURITY: Only add this to .env files on machines where admins run the app.
# Never commit the real value. Never expose it to non-admin users.
VITE_VERIFICATION_SECRET=

# ── Stripe — Monetization Engine ─────────────────────────────────────────────
# Stripe Price IDs — find/create in Stripe Dashboard → Products
# Tier 1: $49 one-time — Live Combine Registration
VITE_STRIPE_PRICE_COMBINE=price_XXXXXXXXXXXXXXXXXX
# Tier 2: $14.99/mo recurring — Athlete Pro
VITE_STRIPE_PRICE_ATHLETE_PRO=price_XXXXXXXXXXXXXXXXXX
# Tier 3: $36,000/yr recurring — Enterprise
VITE_STRIPE_PRICE_ENTERPRISE=price_XXXXXXXXXXXXXXXXXX

# Stripe Payment Links — pre-built checkout URLs (Stripe Dashboard → Payment Links)
# These are the URLs users are sent to for checkout. No server required.
VITE_STRIPE_LINK_COMBINE=https://buy.stripe.com/XXXXXXXXXX
VITE_STRIPE_LINK_ATHLETE_PRO=https://buy.stripe.com/XXXXXXXXXX
VITE_STRIPE_LINK_ENTERPRISE=https://buy.stripe.com/XXXXXXXXXX

# ── Optional / External Integrations ──────────────────────────────────────────
# Canonical app URL (used for OAuth redirects, email links, etc.)
APP_URL=https://your-app.vercel.app
