# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API

# Your project's REST / Auth / Storage / Realtime base URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Public anon key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── Verified Export (admin-only) ──────────────────────────────────────────────
# Used by VerifiedExportButton to authenticate calls to the
# generate-verified-export Edge Function via X-Verification-Secret header.
#
# This MUST match the VERIFICATION_SECRET stored in Supabase Edge Function
# secrets for your project:
#   npx supabase secrets set VERIFICATION_SECRET=<your-secret>
#
# Generate a fresh secret with:
#   openssl rand -hex 32
#
# SECURITY: Only add this to .env files on machines where admins run the app.
# Never commit the real value. Never expose it to non-admin users.
VITE_VERIFICATION_SECRET=

# ── Optional / External Integrations ──────────────────────────────────────────
# Gemini AI (used for admin diagnostics — optional)
GEMINI_API_KEY=

# Canonical app URL (used for OAuth redirects, email links, etc.)
APP_URL=https://your-app.vercel.app
